{
  "name": "ai-frontend-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild dev",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "mock": "node mock/server.cjs",
    "pitfall:scan": "tsx .ai/tools/pitfall-scan.ts",
    "prepare": "husky",
    "prettier": "prettier -c --write . --cache",
    "prettier-import-sort": "npm run prettier -- --plugin=@ianvs/prettier-plugin-sort-imports",
    "preview": "rsbuild preview",
    "type-check": "tsc --noEmit",
    "verify": "tsx .ai/tools/verify-wrapper.ts",
    "verify:fix": "eslint src/ --fix && prettier --write src/",
    "verify:raw": "tsc --noEmit && eslint src/ && prettier --check src/",
    "verify:scope": "tsx .ai/tools/verify-scope.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@ant-design/pro-components": "^2.8.10",
    "@dalydb/sdesign": "^1.10.2",
    "ahooks": "^3.8.0",
    "antd": "^5.29.3",
    "axios": "^1.7.0",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.0",
    "echarts": "^6.1.0",
    "immer": "^11.1.4",
    "lodash-es": "^4.17.0",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.14.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-window": "^1.8.11",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@rsbuild/core": "^1.7.0",
    "@rsbuild/plugin-react": "^1.3.0",
    "@types/lodash-es": "^4.17.0",
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-window": "1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.3",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "json-server": "^0.17.4",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js"
    ]
  },
  "ai": {
    "description": "AI Frontend - Harness Engineering 驱动开发",
    "entry": "AGENTS.md"
  }
}
