{
  "scene": "crud",
  "module": "order",
  "entity": "Order",
  "label": "订单管理",
  "basePath": "/api/order",

  "apiNames": {
    "getList": "queryOrderPage",
    "getById": "getOrderDetail",
    "create": "addOrder",
    "update": "modifyOrder",
    "delete": "removeOrder"
  },

  "fields": [
    { "name": "id", "type": "string", "label": "ID", "required": true },
    {
      "name": "orderNo",
      "type": "string",
      "label": "订单号",
      "required": true
    },
    {
      "name": "customerName",
      "type": "string",
      "label": "客户名称",
      "required": true
    },
    { "name": "amount", "type": "number", "label": "金额", "required": true },
    { "name": "status", "type": "string", "label": "状态", "required": true },
    { "name": "type", "type": "string", "label": "类型", "required": true },
    { "name": "remark", "type": "string", "label": "备注" },
    {
      "name": "createTime",
      "type": "string",
      "label": "创建时间",
      "required": true
    }
  ],

  "enums": [{ "name": "OrderStatus" }, { "name": "OrderType" }],

  "queryParams": [
    {
      "name": "keyword",
      "type": "string",
      "label": "关键词",
      "formType": "input"
    },
    {
      "name": "status",
      "type": "string",
      "label": "状态",
      "formType": "select",
      "enumName": "OrderStatus"
    },
    {
      "name": "type",
      "type": "string",
      "label": "类型",
      "formType": "select",
      "enumName": "OrderType"
    }
  ],

  "listPage": {
    "title": "订单管理",
    "rowKey": "id",
    "columns": [
      { "dataIndex": "orderNo", "title": "订单号", "width": 140 },
      { "dataIndex": "customerName", "title": "客户名称", "width": 150 },
      {
        "dataIndex": "amount",
        "title": "金额",
        "width": 120,
        "render": "amount"
      },
      {
        "dataIndex": "status",
        "title": "状态",
        "width": 100,
        "enumName": "OrderStatus"
      },
      {
        "dataIndex": "type",
        "title": "类型",
        "width": 100,
        "enumName": "OrderType"
      },
      {
        "dataIndex": "createTime",
        "title": "创建时间",
        "width": 180,
        "render": "datetime"
      }
    ],
    "actions": [
      { "label": "查看", "actionType": "view", "handler": "handleDetail" },
      { "label": "编辑", "actionType": "edit", "handler": "handleEdit" },
      {
        "label": "删除",
        "actionType": "delete",
        "handler": "handleDelete",
        "confirm": "确认删除该订单？"
      }
    ],
    "toolbarActions": [
      { "label": "新增", "actionType": "create", "handler": "handleCreate" }
    ]
  },

  "form": {
    "mode": "modal",
    "fields": [
      {
        "name": "orderNo",
        "label": "订单号",
        "type": "input",
        "required": true
      },
      {
        "name": "customerName",
        "label": "客户名称",
        "type": "input",
        "required": true
      },
      {
        "name": "amount",
        "label": "金额",
        "type": "inputNumber",
        "required": true
      },
      { "name": "status", "label": "状态", "type": "select", "required": true },
      { "name": "type", "label": "类型", "type": "select", "required": true },
      { "name": "remark", "label": "备注", "type": "textarea" }
    ]
  },

  "detail": {
    "mode": "drawer",
    "groups": [
      {
        "title": "基本信息",
        "items": [
          { "name": "orderNo", "label": "订单号" },
          { "name": "customerName", "label": "客户名称" },
          { "name": "amount", "label": "金额" },
          { "name": "status", "label": "状态", "enumName": "OrderStatus" },
          { "name": "type", "label": "类型", "enumName": "OrderType" },
          { "name": "remark", "label": "备注" },
          { "name": "createTime", "label": "创建时间" }
        ]
      }
    ]
  }
}
