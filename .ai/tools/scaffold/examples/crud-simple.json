{
  "scene": "crud",
  "module": "user",
  "entity": "User",
  "label": "用户管理",
  "basePath": "/api/user",

  "fields": [
    { "name": "id", "type": "number", "label": "ID", "required": true },
    {
      "name": "username",
      "type": "string",
      "label": "用户名",
      "required": true
    },
    { "name": "email", "type": "string", "label": "邮箱", "required": true },
    { "name": "phone", "type": "string", "label": "手机号" },
    { "name": "status", "type": "number", "label": "状态", "required": true },
    {
      "name": "createdAt",
      "type": "string",
      "label": "创建时间",
      "required": true
    }
  ],

  "enums": [{ "name": "UserStatus" }],

  "queryParams": [
    {
      "name": "keyword",
      "type": "string",
      "label": "关键词",
      "formType": "input"
    },
    {
      "name": "status",
      "type": "number",
      "label": "状态",
      "formType": "select",
      "enumName": "UserStatus"
    }
  ],

  "listPage": {
    "title": "用户列表",
    "columns": [
      { "dataIndex": "id", "title": "ID", "width": 80 },
      { "dataIndex": "username", "title": "用户名", "width": 120 },
      { "dataIndex": "email", "title": "邮箱", "width": 200 },
      { "dataIndex": "phone", "title": "手机号", "width": 140 },
      {
        "dataIndex": "status",
        "title": "状态",
        "width": 100,
        "enumName": "UserStatus"
      },
      {
        "dataIndex": "createdAt",
        "title": "创建时间",
        "width": 180,
        "render": "datetime"
      }
    ],
    "actions": [
      { "label": "查看", "actionType": "view", "handler": "handleDetail" },
      { "label": "编辑", "actionType": "edit", "handler": "handleEdit" },
      {
        "label": "删除",
        "actionType": "delete",
        "handler": "handleDelete",
        "confirm": "确认删除该用户？"
      }
    ],
    "toolbarActions": [
      { "label": "新增", "actionType": "create", "handler": "handleCreate" }
    ]
  },

  "form": {
    "mode": "modal",
    "fields": [
      {
        "name": "username",
        "label": "用户名",
        "type": "input",
        "required": true
      },
      { "name": "email", "label": "邮箱", "type": "input", "required": true },
      { "name": "phone", "label": "手机号", "type": "input" },
      { "name": "status", "label": "状态", "type": "select", "required": true }
    ]
  },

  "detail": {
    "mode": "drawer",
    "groups": [
      {
        "title": "基本信息",
        "items": [
          { "name": "id", "label": "ID" },
          { "name": "username", "label": "用户名" },
          { "name": "email", "label": "邮箱" },
          { "name": "phone", "label": "手机号" },
          { "name": "status", "label": "状态", "enumName": "UserStatus" },
          { "name": "createdAt", "label": "创建时间" }
        ]
      }
    ]
  }
}
