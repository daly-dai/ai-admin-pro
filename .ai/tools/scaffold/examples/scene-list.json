{
  "scene": "list",
  "module": "order",
  "entity": "Order",

  "apiNames": {
    "getList": "queryOrderPage",
    "delete": "removeOrder"
  },

  "queryParams": [
    {
      "name": "keyword",
      "type": "string",
      "label": "关键词",
      "formType": "input"
    },
    {
      "name": "status",
      "type": "string",
      "label": "状态",
      "formType": "select",
      "enumName": "OrderStatus"
    }
  ],

  "enums": [{ "name": "OrderStatus" }],

  "listPage": {
    "title": "订单列表",
    "rowKey": "id",
    "columns": [
      { "dataIndex": "orderNo", "title": "订单号", "width": 140 },
      { "dataIndex": "customerName", "title": "客户名称", "width": 150 },
      {
        "dataIndex": "amount",
        "title": "金额",
        "width": 120,
        "render": "amount"
      },
      {
        "dataIndex": "status",
        "title": "状态",
        "width": 100,
        "enumName": "OrderStatus"
      },
      {
        "dataIndex": "createTime",
        "title": "创建时间",
        "width": 180,
        "render": "datetime"
      }
    ],
    "actions": [
      { "label": "查看", "actionType": "view", "handler": "handleDetail" },
      { "label": "编辑", "actionType": "edit", "handler": "handleEdit" },
      {
        "label": "删除",
        "actionType": "delete",
        "handler": "handleDelete",
        "confirm": "确认删除该订单？"
      }
    ],
    "toolbarActions": [
      { "label": "新增", "actionType": "create", "handler": "handleCreate" }
    ]
  },

  "form": { "mode": "modal" },
  "detail": { "mode": "drawer" }
}
