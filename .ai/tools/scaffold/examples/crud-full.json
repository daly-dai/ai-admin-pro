{
  "scene": "crud",
  "module": "contract",
  "entity": "Contract",
  "label": "合同管理",
  "basePath": "/api/contract",

  "apiNames": {
    "getList": "queryContractPage",
    "getById": "getContractDetail",
    "create": "addContract",
    "update": "modifyContract",
    "delete": "removeContract"
  },

  "fields": [
    { "name": "id", "type": "string", "label": "主键", "required": true },
    {
      "name": "contractNo",
      "type": "string",
      "label": "合同编号",
      "required": true
    },
    {
      "name": "title",
      "type": "string",
      "label": "合同标题",
      "required": true
    },
    { "name": "partyA", "type": "string", "label": "甲方", "required": true },
    { "name": "partyB", "type": "string", "label": "乙方", "required": true },
    {
      "name": "amount",
      "type": "number",
      "label": "合同金额（元）",
      "required": true
    },
    {
      "name": "signDate",
      "type": "string",
      "label": "签约日期",
      "required": true
    },
    {
      "name": "startDate",
      "type": "string",
      "label": "生效日期",
      "required": true
    },
    {
      "name": "endDate",
      "type": "string",
      "label": "到期日期",
      "required": true
    },
    {
      "name": "status",
      "type": "string",
      "label": "合同状态",
      "required": true
    },
    { "name": "type", "type": "string", "label": "合同类型", "required": true },
    { "name": "remark", "type": "string", "label": "备注" },
    {
      "name": "createTime",
      "type": "string",
      "label": "创建时间",
      "required": true
    },
    {
      "name": "updateTime",
      "type": "string",
      "label": "更新时间",
      "required": true
    }
  ],

  "enums": [
    {
      "name": "ContractStatus",
      "entries": [
        { "value": "draft", "label": "草稿" },
        { "value": "pending_review", "label": "待审批" },
        { "value": "approved", "label": "已审批" },
        { "value": "active", "label": "执行中" },
        { "value": "completed", "label": "已完成" },
        { "value": "terminated", "label": "已终止" }
      ]
    },
    {
      "name": "ContractType",
      "entries": [
        { "value": "purchase", "label": "采购合同" },
        { "value": "sales", "label": "销售合同" },
        { "value": "service", "label": "服务合同" },
        { "value": "lease", "label": "租赁合同" }
      ]
    }
  ],

  "queryParams": [
    {
      "name": "keyword",
      "type": "string",
      "label": "关键词",
      "formType": "input"
    },
    {
      "name": "status",
      "type": "string",
      "label": "状态",
      "formType": "select",
      "enumName": "ContractStatus"
    },
    {
      "name": "type",
      "type": "string",
      "label": "类型",
      "formType": "select",
      "enumName": "ContractType"
    },
    {
      "name": "signDateRange",
      "type": "[string, string]",
      "label": "签约日期",
      "formType": "SDatePickerRange"
    }
  ],

  "extraApis": [
    {
      "name": "submitReview",
      "method": "PUT",
      "path": "/{id}/submit",
      "desc": "提交审批",
      "params": [{ "name": "id", "type": "string" }]
    },
    {
      "name": "approve",
      "method": "PUT",
      "path": "/{id}/approve",
      "desc": "审批通过",
      "params": [{ "name": "id", "type": "string" }]
    },
    {
      "name": "batchApprove",
      "method": "PUT",
      "path": "/batch-approve",
      "desc": "批量审批",
      "body": [{ "name": "ids", "type": "string[]" }]
    },
    {
      "name": "terminate",
      "method": "PUT",
      "path": "/{id}/terminate",
      "desc": "终止合同",
      "params": [{ "name": "id", "type": "string" }]
    }
  ],

  "listPage": {
    "title": "合同管理",
    "searchColumns": 4,
    "rowKey": "id",
    "rowSelection": true,
    "columns": [
      { "dataIndex": "contractNo", "title": "合同编号", "width": 120 },
      {
        "dataIndex": "title",
        "title": "合同标题",
        "width": 200,
        "render": "ellipsis"
      },
      { "dataIndex": "partyA", "title": "甲方", "width": 150 },
      { "dataIndex": "partyB", "title": "乙方", "width": 150 },
      {
        "dataIndex": "amount",
        "title": "金额",
        "width": 120,
        "render": "amount"
      },
      {
        "dataIndex": "signDate",
        "title": "签约日期",
        "width": 120,
        "render": "date"
      },
      {
        "dataIndex": "status",
        "title": "状态",
        "width": 100,
        "enumName": "ContractStatus"
      }
    ],
    "actions": [
      { "label": "查看", "actionType": "view", "handler": "handleDetail" },
      {
        "label": "编辑",
        "actionType": "edit",
        "handler": "handleEdit",
        "condition": "record.status === 'draft' || record.status === 'pending_review'"
      },
      {
        "label": "删除",
        "actionType": "delete",
        "handler": "handleDelete",
        "confirm": "确认删除该合同？删除后不可恢复。",
        "condition": "record.status === 'draft'"
      },
      {
        "label": "提交审批",
        "actionType": "t-link",
        "handler": "handleSubmitReview",
        "condition": "record.status === 'draft'"
      }
    ],
    "toolbarActions": [
      { "label": "新增", "actionType": "create", "handler": "handleCreate" },
      {
        "label": "批量审批",
        "actionType": "confirm",
        "handler": "handleBatchApprove"
      }
    ]
  },

  "form": {
    "mode": "page",
    "columns": 2,
    "fields": [
      {
        "name": "contractNo",
        "label": "合同编号",
        "type": "input",
        "required": true
      },
      {
        "name": "title",
        "label": "合同标题",
        "type": "input",
        "required": true
      },
      {
        "name": "type",
        "label": "合同类型",
        "type": "select",
        "required": true
      },
      { "name": "partyA", "label": "甲方", "type": "input", "required": true },
      { "name": "partyB", "label": "乙方", "type": "input", "required": true },
      {
        "name": "amount",
        "label": "合同金额",
        "type": "inputNumber",
        "required": true,
        "fieldProps": { "min": 0, "precision": 2, "style": { "width": "100%" } }
      },
      {
        "name": "signDate",
        "label": "签约日期",
        "type": "SDatePicker",
        "required": true
      },
      {
        "name": "startDate",
        "label": "生效日期",
        "type": "SDatePicker",
        "required": true
      },
      {
        "name": "endDate",
        "label": "到期日期",
        "type": "SDatePicker",
        "required": true
      },
      { "name": "remark", "label": "备注", "type": "textarea", "colSpan": 24 }
    ],
    "watchRules": [
      {
        "watchField": "type",
        "condition": "value === 'lease'",
        "fields": [
          {
            "name": "leaseTerm",
            "label": "租赁期限(月)",
            "type": "inputNumber",
            "fieldProps": { "min": 1 }
          }
        ]
      }
    ]
  },

  "detail": {
    "mode": "page",
    "column": 2,
    "groups": [
      {
        "title": "基本信息",
        "items": [
          { "name": "contractNo", "label": "合同编号" },
          { "name": "title", "label": "合同标题" },
          { "name": "type", "label": "合同类型", "enumName": "ContractType" },
          {
            "name": "status",
            "label": "合同状态",
            "enumName": "ContractStatus"
          }
        ]
      },
      {
        "title": "合同双方",
        "items": [
          { "name": "partyA", "label": "甲方" },
          { "name": "partyB", "label": "乙方" }
        ]
      },
      {
        "title": "金额与日期",
        "items": [
          {
            "name": "amount",
            "label": "合同金额",
            "render": "(val: number) => val?.toLocaleString('zh-CN', { minimumFractionDigits: 2 })"
          },
          { "name": "signDate", "label": "签约日期" },
          { "name": "startDate", "label": "生效日期" },
          { "name": "endDate", "label": "到期日期" }
        ]
      },
      {
        "title": "其他",
        "items": [
          { "name": "remark", "label": "备注" },
          { "name": "createTime", "label": "创建时间" },
          { "name": "updateTime", "label": "更新时间" }
        ]
      }
    ]
  }
}
